// Schema Lume v0.1
// Riferimento: documento "Lume, specifica scientifico-tecnica e brief operativo" sezione 9.2.
// Estensioni rispetto alla bozza del documento:
//   - FactorScore e CompositeScore separati da Session (query analitiche piu pulite)
//   - ConsentRecord versionato (servizio + ricerca, revoca tracciata)
//   - SampleStat per medie e SD del campione (batch giornaliero, alimenta z-score)
//   - ResearchExport per pipeline di anonimizzazione

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ---------------------------------------------------------------------------
// Auth, NextAuth standard models (credentials + email magic link)
// ---------------------------------------------------------------------------

model User {
  id              String    @id @default(cuid())
  email           String    @unique
  emailVerified   DateTime?
  passwordHash    String?
  name            String?
  image           String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  // demografia minima richiesta in onboarding (sezione 7.1)
  birthYear       Int?
  gender          String?   // self-described, libero
  educationLevel  String?   // none|primary|secondary|bachelor|master|phd
  nativeLanguage  String?
  neurodivergence String?   // self-reported, opzionale

  accounts        Account[]
  authSessions    AuthSession[]
  consents        ConsentRecord[]
  sessions        AssessmentSession[]
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model AuthSession {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ---------------------------------------------------------------------------
// Consenso versionato. Servizio = obbligatorio, ricerca = opzionale e revocabile.
// ---------------------------------------------------------------------------

model ConsentRecord {
  id                String   @id @default(cuid())
  userId            String
  consentVersion    String   // es. "2026-05-01"
  serviceConsent    Boolean  // necessario per usare Lume
  researchConsent   Boolean  // opzionale, alimenta dataset di ricerca
  signedAt          DateTime @default(now())
  revokedAt         DateTime?
  ipHash            String?  // SHA-256 IP, mai IP in chiaro
  userAgent         String?

  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, signedAt])
}

// ---------------------------------------------------------------------------
// Assessment domain
// ---------------------------------------------------------------------------

enum FactorCode {
  Gf
  Gwm
  Gs
  Gv
  Gc
}

enum SessionStatus {
  in_progress
  completed
  abandoned
}

model AssessmentSession {
  id                String          @id @default(cuid())
  userId            String
  startedAt         DateTime        @default(now())
  completedAt       DateTime?
  status            SessionStatus   @default(in_progress)

  // metadata di calibrazione
  appVersion        String          // es. "0.1.0"
  consentVersion    String          // versione del consenso firmata al momento

  // QC: sessioni con qcPassed = false NON producono ICL (sezione 5.4.1).
  qcPassed          Boolean?
  qcFlags           Json?           // motivi del fallimento QC

  trials            Trial[]
  taskInstances     TaskInstance[]
  factorScores      FactorScore[]
  compositeScore    CompositeScore?

  user              User            @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, startedAt])
  @@index([status])
}

enum TaskStatus {
  not_started
  in_progress
  completed
  skipped
}

model TaskInstance {
  id           String     @id @default(cuid())
  sessionId    String
  taskCode     String     // matrix, series, digit_span_back, corsi, nback, symbol_match, choice_rt, mental_rotation, paper_folding, vocabulary, verbal_inference
  status       TaskStatus @default(not_started)
  startedAt    DateTime?
  completedAt  DateTime?
  // raw score sintetico per la singola istanza (interpretazione dipende dal task)
  rawScore     Float?
  // metadati addizionali (es. span massimo raggiunto, d-prime, accuracy)
  details      Json?

  session      AssessmentSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@unique([sessionId, taskCode])
  @@index([sessionId, status])
}

model Trial {
  id            String   @id @default(cuid())
  sessionId     String
  taskCode      String   // matrix, series, digit_span_back, corsi, nback, ...
  itemSeed      String   // PRNG seed per riproducibilita
  itemMeta      Json     // difficolta, parametri, regole attive
  response      Json
  rtMs          Int?
  correct       Boolean?
  presentedAt   DateTime
  respondedAt   DateTime?

  session       AssessmentSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@index([sessionId, taskCode])
  @@index([taskCode])
}

// Item bank statico (es. vocabolario, inferenze verbali). Versionati e calibrabili IRT.
model ItemBankEntry {
  id               String   @id @default(cuid())
  taskCode         String
  externalId       String   // codice leggibile, es. "voc-0123"
  content          Json
  // Parametri IRT (popolati post-calibrazione, null in v1)
  irtA             Float?   // discriminazione (2PL)
  irtB             Float?   // difficolta
  irtC             Float?   // guessing (3PL)
  difficultyTier   Int      @default(0)
  active           Boolean  @default(true)
  version          Int      @default(1)
  createdAt        DateTime @default(now())

  @@unique([taskCode, externalId, version])
  @@index([taskCode, active])
}

// ---------------------------------------------------------------------------
// Score derivati. Calcolati al completamento e ricalcolabili in batch quando
// SampleStat cambia (sezione 5.4.1, formula v1).
// ---------------------------------------------------------------------------

model FactorScore {
  id            String     @id @default(cuid())
  sessionId     String
  factor        FactorCode
  rawScore      Float
  zScore        Float      // calcolato vs SampleStat corrente
  alpha         Float?     // alpha di Cronbach interno al fattore, se calcolabile
  computedAt    DateTime   @default(now())
  formulaVersion String    @default("v1")

  session       AssessmentSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@unique([sessionId, factor])
}

model CompositeScore {
  id              String   @id @default(cuid())
  sessionId       String   @unique
  // ICL su scala 100 +/- 20, range pratico [40, 160] con troncamento (sezione 5.4.1)
  icl             Float
  se              Float    // errore standard di misura
  lowerCI         Float    // icl - se
  upperCI         Float    // icl + se
  qcPassed        Boolean
  formulaVersion  String   @default("v1")
  weights         Json     // pesi per fattore (v1: 0.20 ciascuno)
  sampleStatId    String?  // riferimento al batch SampleStat usato
  computedAt      DateTime @default(now())

  session         AssessmentSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  sampleStat      SampleStatBatch?  @relation(fields: [sampleStatId], references: [id])
}

// ---------------------------------------------------------------------------
// Statistiche del campione Lume. Ricalcolate in batch notturno.
// In v1 e v2 sono il riferimento per gli z-score (campione interno autoselezionato).
// In v3 verranno sostituite o affiancate da norme italiane stratificate.
// ---------------------------------------------------------------------------

model SampleStatBatch {
  id              String     @id @default(cuid())
  computedAt      DateTime   @default(now())
  sessionCount    Int        // sessioni qcPassed incluse
  formulaVersion  String     @default("v1")

  factorStats     SampleStat[]
  composites      CompositeScore[]
}

model SampleStat {
  id          String          @id @default(cuid())
  batchId     String
  factor      FactorCode
  mean        Float
  sd          Float
  n           Int

  batch       SampleStatBatch @relation(fields: [batchId], references: [id], onDelete: Cascade)

  @@unique([batchId, factor])
}

// ---------------------------------------------------------------------------
// Pipeline ricerca. Anonimizzazione separata, surrogate id non reversibile.
// Solo sessioni con researchConsent = true e qcPassed = true.
// ---------------------------------------------------------------------------

model ResearchExport {
  id             String   @id @default(cuid())
  surrogateId    String   @unique
  sessionId      String   @unique
  payload        Json     // trial + score + demografia anonimizzata
  exportedAt     DateTime @default(now())
  consentVersion String
}
